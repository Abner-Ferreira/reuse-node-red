        "name": "Limpa contexto",
        "func": "flow.set('productToDelete', null);\nflow.set('productName', null);\nmsg.payload = '';\nmsg.topic   = 'clear_modal';\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
