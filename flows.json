        "type": "http request",
        "z": "tab_admin",
        "name": "GET /api/products",
        "method": "GET",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://localhost:3000/api/products",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
        "headers": [],
        "x": 610,
        "y": 180,
        "wires": [
            [
                "fn_formata_lista",
                "fn_check_get_error"
            ]
        ]
    },
    {
        "id": "fn_check_get_error",
        "type": "function",
        "z": "tab_admin",
        "name": "Verifica erro GET",
        "func": "if (msg.statusCode !== 200) {\n  msg.payload = \"❌ Erro ao carregar produtos (status \" + msg.statusCode + \")\";\n  node.error(msg.payload, msg);\n}\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 830,
        "y": 130,
        "wires": [
            []
        ]
    },
    {
        "id": "fn_formata_lista",
        "type": "function",
        "z": "tab_admin",
        "name": "Formata tabela HTML",
        "func": "var products = msg.payload;\n\nif (!Array.isArray(products)) {\n  node.warn('Resposta inesperada da API: ' + JSON.stringify(products));\n  msg.payload = '<p style=\"color:#D32F2F\">Erro: resposta inesperada da API.</p>';\n  return msg;\n}\n\nif (products.length === 0) {\n  msg.payload = '<p style=\"color:#505050;text-align:center;padding:20px\">Nenhum produto encontrado.</p>';\n  return msg;\n}\n\nvar html = `\n<style>\n  .prod-table { width:100%; border-collapse:collapse; font-family:sans-serif; font-size:14px; color: #212121; }\n  .prod-table th { background:#2E7D32; color:#F5F5F5; padding:10px 12px; text-align:left; }\n  .prod-table td { padding:9px 12px; border-bottom:1px solid #e0e0e0; vertical-align:middle; }\n  .prod-table tr:hover td { background:#f5f5f5; }\n  .badge { display:inline-block; padding:2px 8px; border-radius:12px; font-size:12px; font-weight:600; }\n  .badge-active { background:#c8e6c9; color:#2e7d32; }\n  .badge-inactive { background:#ffcdd2; color:#c62828; }\n  .btn-del { background:#D32F2F; color:#F5F5F5; border:none; padding:5px 14px;\n             border-radius:4px; cursor:pointer; font-size:13px; transition:background .2s; }\n  .btn-del:hover { background:#D32F2FFF; }\n  .prod-header { display:flex; align-items:center; justify-content:space-between;\n                 margin-bottom:12px; }\n  .prod-header h3 { margin:0; color:#2E7D32; font-size:16px; }\n  .prod-count { background:#66bb6a6c; color:#2E7D32; padding:3px 10px;\n                border-radius:12px; font-size:13px; font-weight:600; }\n</style>\n<div class=\"prod-header\">\n  <h3>📦 Produtos Cadastrados</h3>\n  <span class=\"prod-count\">${products.length} produto(s)</span>\n</div>\n<table class=\"prod-table\">\n  <thead>\n    <tr>\n      <th>#ID</th>\n      <th>Nome</th>\n      <th>Categoria</th>\n      <th>Preço</th>\n      <th>Status</th>\n      <th>Ação</th>\n    </tr>\n  </thead>\n  <tbody>\n`;\n\nproducts.forEach(function(p) {\n  var price = (p.price !== undefined)\n    ? 'R$ ' + parseFloat(p.price).toFixed(2).replace('.', ',')\n    : 'N/A';\n  var category = p.category || p.categoryName || '-';\n  var statusLabel = (p.status === 'ativo' || p.active === true)\n    ? '<span class=\"badge badge-active\">Ativo</span>'\n    : '<span class=\"badge badge-inactive\">Inativo</span>';\n\n  html += `<tr>\n    <td>${p.id}</td>\n    <td><strong>${p.name || p.title || 'Sem nome'}</strong></td>\n    <td>${category}</td>\n    <td>${price}</td>\n    <td>${statusLabel}</td>\n    <td>\n     <button class=\"btn-del\"\n  onclick=\"enviarDelete('${p.id}', '${(p.name || p.title || '').replace(/'/g, '')}')\">\n  🗑 Excluir\n</button>\n\n    </td>\n  </tr>`;\n});\n\nhtml += `</tbody></table>`;\nmsg.payload = html;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 830,
        "y": 180,
        "wires": [
            [
                "ui_tabela_produtos"
            ]
        ]
