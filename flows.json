        "type": "function",
        "z": "tab_admin",
        "name": "Monta requisição DELETE",
        "func": "var id = flow.get('productToDelete');\nif (!id) {\n  node.warn('Nenhum produto selecionado para exclusão');\n  return null;\n}\nmsg.url    = 'http://localhost:3000/api/products/' + id;\nmsg.method = 'DELETE';\nmsg.payload = {};\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
