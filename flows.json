        ]
    },
    {
        "id": "fn_salva_id",
        "type": "function",
        "z": "tab_admin",
        "name": "Salva ID no contexto",
        "func": "flow.set('productToDelete', msg.payload);\nflow.set('productName', msg.productName || msg.payload);\nmsg.payload = msg.productName || ('ID: ' + msg.payload);\nconsole.log(msg)\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 830,
        "y": 290,
