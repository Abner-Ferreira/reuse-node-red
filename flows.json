    {
        "id": "ui_modal_confirmacao",
        "type": "ui_template",
        "z": "tab_admin",
        "group": "group_painel",
        "name": "Modal de Confirmação",
        "order": 3,
        "width": 24,
        "height": 2,
        "format": "<style>\n  .modal-confirm {\n    background: #F5F5F5;\n    border: 1px solid #66BB6A;\n    border-radius: 8px;\n    padding: 16px 20px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 12px;\n  }\n\n  .modal-confirm p {\n    margin: 0;\n    font-size: 14px;\n    color: #e65100;\n    font-weight: 600;\n  }\n\n  .btn-yes {\n    background: rgba(183, 28, 28, 0.705);\n    color: #F5F5F5;\n    border: none;\n    padding: 8px 20px;\n    border-radius: 4px;\n    cursor: pointer;\n    font-size: 14px;\n    font-weight: 600;\n  }\n\n  .btn-yes:hover {\n    background: #D32F2F;\n  }\n\n  .btn-no {\n    background: #757575;\n    color: #F5F5F5;\n    border: none;\n    padding: 8px 20px;\n    border-radius: 4px;\n    cursor: pointer;\n    font-size: 14px;\n  }\n\n  .btn-no:hover {\n    background: #424242;\n  }\n</style>\n<div class=\"modal-confirm\" ng-show=\"msg.payload\">\n  <p>Deseja excluir o produto: <em>{{msg.payload}}</em>?</p>\n  <div>\n    <button\n      class=\"btn-yes\"\n      ng-click=\"send({payload:true, topic:'confirm_delete'})\"\n    >\n      Excluir\n    </button>\n    &nbsp;\n    <button\n      class=\"btn-no\"\n      ng-click=\"send({payload:false, topic:'cancel_delete'})\"\n    >\n      Cancelar\n    </button>\n  </div>\n</div>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": false,
        "templateScope": "local",
        "className": "",
        "x": 1050,
        "y": 290,
        "wires": [
            [
                "sw_confirmacao"
            ]
        ]
    },
