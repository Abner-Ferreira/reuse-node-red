    {
        "id": "fn_sucesso",
        "type": "function",
        "z": "tab_admin",
        "name": "Prepara msg sucesso",
        "func": "var name = flow.get('productName') || flow.get('productToDelete');\nflow.set('productToDelete', null);\nflow.set('productName', null);\nmsg.payload = '✅ Produto \"' + name + '\" removido com sucesso!';\nmsg.topic   = 'clear_modal';\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 830,
        "y": 510,
        "wires": [
