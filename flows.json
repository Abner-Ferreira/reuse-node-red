    {
        "id": "ui_tabela_produtos",
        "type": "ui_template",
        "z": "tab_admin",
        "group": "group_painel",
        "name": "Tabela de Produtos",
        "order": 4,
        "width": 24,
        "height": 11,
        "format": "<div ng-bind-html=\"msg.payload | trusted\"></div>\n\n<script>\n    (function(scope) {\n\n    window.enviarDelete = function(id, name) {\n        scope.send({\n            payload: id,\n            topic: 'delete_product',\n            productName: name\n        });\n    };\n\n})(scope);\n</script>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 1050,
        "y": 180,
        "wires": [
            [
                "sw_captura_clique"
            ]
        ]
    },
    {
        "id": "sw_captura_clique",
        "type": "switch",
        "z": "tab_admin",
        "name": "Filtra: delete_product",
        "property": "topic",
        "propertyType": "msg",
        "rules": [
            {
                "t": "eq",
                "v": "delete_product",
                "vt": "str"
            }
        ],
        "checkall": "true",
        "repair": false,
        "outputs": 1,
        "x": 610,
        "y": 290,
        "wires": [
            [
                "fn_salva_id"
